<?xml version="1.0"?>
<launch>
    <node pkg="route_maker" type="make_guide_line.py" name="make_guide_line" output="screen" >
        <param name="WALL_FILE" value="$(find wall_line_matcher)/config/test_wall.yaml" />
        <param name="WALL_DIST" value="0.5" />
        <param name="HZ" value="10" />
    </node>

</launch>
